{
  "schemaVersion": 1,

  "id": "strand",
  "version": "${version}",

  "name": "Strand",
  "description": "Open your Minecraft world to anyone, anywhere.",

  "authors": [
    {
      "name": "Lilith",
      "contact": {
        "homepage": "https://lilith.re/",
        "email": "hello@lilith.re"
      }
    }
  ],

  "contact": {
    "issues": "https://github.com/LilithTechnologies/Strand/issues",
    "sources": "https://github.com/LilithTechnologies/Strand",
    "homepage": "https://github.com/LilithTechnologies/Strand"
  },

  "license": "AGPL-3.0",
  "icon": "assets/strand/icon.png",

  "environment": "client",

  "mixins": [
    "strand.mixins.json"
  ],
  "entrypoints": {
    "client": [
      "re.lilith.strand.platform.fabric.StrandClient"
    ]
  },

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
